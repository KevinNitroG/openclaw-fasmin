{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Asia/Ho_Chi_Minh",
  "schedule": ["* 0-4 * * 0,6"],
  "mise": {
    "managerFilePatterns": ["/(^|/)mise\\.claw\\.toml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/scripts/setup/40-openclaw\\.sh$/"],
      "matchStrings": ["OFFICIAL_VERSION=\"(?<currentValue>\\d+\\.\\d+\\.\\d+)\""],
      "depNameTemplate": "openclaw",
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["npm:openclaw", "openclaw"],
      "groupName": "openclaw",
      "groupSlug": "openclaw"
    }
  ]
}
