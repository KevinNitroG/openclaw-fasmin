# /home/claw/.bashrc — interactive shell setup for the claw user
case $- in *i*) ;; *) return ;; esac # only for interactive shells

export EDITOR=vim
export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:/home/linuxbrew/.linuxbrew/bin:$PATH"

# OPENCLAW_* / runtime env (state dir, config path, telemetry). Login shells get this via
# /etc/profile.d; source it here too so non-login interactive shells (plain `bash`,
# `docker exec ... bash`) point at the same volume paths the gateway uses.
[ -f /etc/profile.d/10-openclaw-env.sh ] && . /etc/profile.d/10-openclaw-env.sh

# Point the openclaw CLI/TUI at the gateway's actual port. The gateway binds $PORT
# (Railway-injected; falls back to 18789), but the CLI defaults to 18789 — so without this
# `openclaw tui` etc. would miss the gateway in-container. Honors a pre-set value.
export OPENCLAW_GATEWAY_PORT="${OPENCLAW_GATEWAY_PORT:-${PORT:-18789}}"

# mise activation (adds tools to PATH dynamically for this shell)
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate bash)"
fi

# zoxide (smarter cd; provides `z`)
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init bash)"
fi

# OpenClaw Completion
[ -f "$HOME/.local/share/bash-completion/openclaw.bash" ] && source "$HOME/.local/share/bash-completion/openclaw.bash"

alias ll='ls -alh'
